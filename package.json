{
  "name": "pz-server-manager",
  "version": "1.2.3",
  "description": "Project Zomboid Build 42 Dedicated Server Manager",
  "main": "dist/main.js",
  "scripts": {
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "vite build --config vite.renderer.config.ts",
    "build:electron": "tsc --project tsconfig.electron.json",
    "start": "npm run build && npm run launch",
    "launch": "node scripts/launch.js",
    "dev": "npm run build:electron && node scripts/dev.js",
    "dist:win": "npm run build && electron-builder --win",
    "dist:win:dir": "npm run build && electron-builder --win --dir",
    "publish": "npm run build && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.pzservermanager.app",
    "productName": "PZ Server Manager",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PZ Server Manager",
      "artifactName": "PZ-Server-Manager-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "bp8np4fh6b-del",
      "repo": "Project-Zomboid-Server-Manager",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "recharts": "^2.10.0"
  }
}
